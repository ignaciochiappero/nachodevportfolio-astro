---
import FloatingSphereChat from "./FloatingSphereChat.astro";
---

<div class="tech-backdrop" aria-hidden="true">
	<canvas class="tech-backdrop__canvas" data-tech-particles></canvas>
</div>

<FloatingSphereChat mode="fixed" position={{ bottom: "1rem", right: "1rem" }} />

<script>
	import * as THREE from "three";

	const particleCanvas = document.querySelector("[data-tech-particles]");

	if (particleCanvas instanceof HTMLCanvasElement) {
		const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
		const reduceMotion = mediaQuery.matches;
		const isMobile = window.innerWidth < 768;
		const cleanups: Array<() => void> = [];

		const particleRenderer = new THREE.WebGLRenderer({
			canvas: particleCanvas,
			alpha: true,
			antialias: true,
			powerPreference: "high-performance",
		});
		particleRenderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.75));
		particleRenderer.outputColorSpace = THREE.SRGBColorSpace;

		const particleScene = new THREE.Scene();
		const particleCamera = new THREE.PerspectiveCamera(42, 1, 0.1, 100);
		particleCamera.position.z = 20;

		const particleCount = isMobile ? 700 : 1500;
		const positions = new Float32Array(particleCount * 3);
		const colors = new Float32Array(particleCount * 3);
		const seeds = new Float32Array(particleCount * 4);

		const nearColor = new THREE.Color("#111111");
		const farColor = new THREE.Color("#8c877f");

		for (let index = 0; index < particleCount; index += 1) {
			const stride = index * 3;
			positions[stride] = (Math.random() - 0.5) * 26;
			positions[stride + 1] = (Math.random() - 0.5) * 20;
			positions[stride + 2] = (Math.random() - 0.5) * 18;

			const blend = Math.random();
			const mixed = nearColor.clone().lerp(farColor, blend * 0.65);
			colors[stride] = mixed.r;
			colors[stride + 1] = mixed.g;
			colors[stride + 2] = mixed.b;

			const seedStride = index * 4;
			seeds[seedStride] = positions[stride];
			seeds[seedStride + 1] = positions[stride + 1];
			seeds[seedStride + 2] = Math.random() * Math.PI * 2;
			seeds[seedStride + 3] = 0.2 + Math.random() * 0.55;
		}

		const particleGeometry = new THREE.BufferGeometry();
		particleGeometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
		particleGeometry.setAttribute("color", new THREE.BufferAttribute(colors, 3));

		const particleMaterial = new THREE.PointsMaterial({
			size: isMobile ? 0.075 : 0.065,
			vertexColors: true,
			transparent: true,
			opacity: 0.4,
			depthWrite: false,
			blending: THREE.NormalBlending,
			sizeAttenuation: true,
		});

		const particleCloud = new THREE.Points(particleGeometry, particleMaterial);
		particleScene.add(particleCloud);

		const resizeParticles = () => {
			particleCamera.aspect = window.innerWidth / window.innerHeight;
			particleCamera.updateProjectionMatrix();
			particleRenderer.setSize(window.innerWidth, window.innerHeight, false);
		};

		resizeParticles();

		const resizeObserver = new ResizeObserver(() => {
			resizeParticles();
		});
		resizeObserver.observe(document.body);
		cleanups.push(() => resizeObserver.disconnect());

		const handleResize = () => {
			resizeParticles();
		};

		window.addEventListener("resize", handleResize);
		cleanups.push(() => window.removeEventListener("resize", handleResize));

		const clock = new THREE.Clock();
		let frameId = 0;

		const renderFrame = () => {
			const elapsed = clock.getElapsedTime();
			const positionAttribute = particleGeometry.getAttribute("position");

			for (let index = 0; index < particleCount; index += 1) {
				const stride = index * 3;
				const seedStride = index * 4;
				const phase = elapsed * seeds[seedStride + 3] + seeds[seedStride + 2];
				positionAttribute.array[stride] =
					seeds[seedStride] + Math.cos(phase * 0.6) * 0.16;
				positionAttribute.array[stride + 1] =
					seeds[seedStride + 1] + Math.sin(phase) * 0.28;
				positionAttribute.array[stride + 2] =
					Math.sin(phase * 0.8) * 1.4 + (index % 11) * 0.03 - 0.4;
			}

			positionAttribute.needsUpdate = true;
			particleCloud.rotation.y = elapsed * 0.025;
			particleCloud.rotation.x = -0.08;
			particleRenderer.render(particleScene, particleCamera);

			if (!reduceMotion) {
				frameId = window.requestAnimationFrame(renderFrame);
			}
		};

		renderFrame();

		const cleanup = () => {
			window.cancelAnimationFrame(frameId);
			cleanups.forEach((dispose) => dispose());
			particleGeometry.dispose();
			particleMaterial.dispose();
			particleRenderer.dispose();
		};

		window.addEventListener("pagehide", cleanup, { once: true });
	}
</script>