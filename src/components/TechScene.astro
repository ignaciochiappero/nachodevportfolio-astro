---
import FloatingSphereChat from "./FloatingSphereChat.astro";
---

<div class="tech-backdrop" aria-hidden="true">
	<canvas class="tech-backdrop__canvas" data-shader-bg></canvas>
</div>

<FloatingSphereChat mode="fixed" position={{ bottom: "1rem", right: "1rem" }} />

<script>
	import * as THREE from "three";

	const canvasEl = document.querySelector("[data-shader-bg]");

	if (canvasEl instanceof HTMLCanvasElement) {
		const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
		const reduceMotion = mediaQuery.matches;
		const cleanups: Array<() => void> = [];

		// ── Renderer ──────────────────────────────────────────────────────────────
		const renderer = new THREE.WebGLRenderer({
			canvas: canvasEl,
			antialias: false,
			alpha: false,
			powerPreference: "low-power",
		});
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));

		// ── Scene & Camera ────────────────────────────────────────────────────────
		// Orthographic camera: full-screen quad. No perspective needed.
		const scene = new THREE.Scene();
		const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

		// ── Shaders ───────────────────────────────────────────────────────────────
		const vertexShader = /* glsl */ `
			varying vec2 vUv;
			void main() {
				vUv = uv;
				gl_Position = vec4(position.xy, 0.0, 1.0);
			}
		`;

		// Full 3D simplex noise + flowing noise field fragment shader
		const fragmentShader = /* glsl */ `
			precision mediump float;

			uniform float uTime;
			uniform vec2  uResolution;
			uniform vec2  uMouse;

			varying vec2 vUv;

			// ── Simplex Noise 3D ─────────────────────────────────────────────────
			vec3 mod289v3(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
			vec4 mod289v4(vec4 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
			vec4 permute(vec4 x)  { return mod289v4(((x * 34.0) + 1.0) * x); }
			vec4 taylorInvSqrt(vec4 r) { return 1.79284291400159 - 0.85373472095314 * r; }

			float snoise(vec3 v) {
				const vec2 C = vec2(1.0 / 6.0, 1.0 / 3.0);
				const vec4 D = vec4(0.0, 0.5, 1.0, 2.0);

				// First corner
				vec3 i  = floor(v + dot(v, C.yyy));
				vec3 x0 = v - i + dot(i, C.xxx);

				// Other corners
				vec3 g  = step(x0.yzx, x0.xyz);
				vec3 l  = 1.0 - g;
				vec3 i1 = min(g.xyz, l.zxy);
				vec3 i2 = max(g.xyz, l.zxy);

				vec3 x1 = x0 - i1  + C.xxx;
				vec3 x2 = x0 - i2  + C.yyy;
				vec3 x3 = x0 - D.yyy;

				// Permutations
				i = mod289v3(i);
				vec4 p = permute(permute(permute(
					i.z + vec4(0.0, i1.z, i2.z, 1.0))
					+ i.y + vec4(0.0, i1.y, i2.y, 1.0))
					+ i.x + vec4(0.0, i1.x, i2.x, 1.0));

				// Gradients
				float n_ = 0.142857142857;
				vec3 ns = n_ * D.wyz - D.xzx;

				vec4 j = p - 49.0 * floor(p * ns.z * ns.z);
				vec4 x_ = floor(j * ns.z);
				vec4 y_ = floor(j - 7.0 * x_);
				vec4 x  = x_ * ns.x + ns.yyyy;
				vec4 y  = y_ * ns.x + ns.yyyy;
				vec4 h  = 1.0 - abs(x) - abs(y);

				vec4 b0 = vec4(x.xy, y.xy);
				vec4 b1 = vec4(x.zw, y.zw);

				vec4 s0 = floor(b0) * 2.0 + 1.0;
				vec4 s1 = floor(b1) * 2.0 + 1.0;
				vec4 sh = -step(h, vec4(0.0));

				vec4 a0 = b0.xzyw + s0.xzyw * sh.xxyy;
				vec4 a1 = b1.xzyw + s1.xzyw * sh.zzww;

				vec3 p0 = vec3(a0.xy, h.x);
				vec3 p1 = vec3(a0.zw, h.y);
				vec3 p2 = vec3(a1.xy, h.z);
				vec3 p3 = vec3(a1.zw, h.w);

				// Normalise
				vec4 norm = taylorInvSqrt(vec4(dot(p0, p0), dot(p1, p1), dot(p2, p2), dot(p3, p3)));
				p0 *= norm.x;
				p1 *= norm.y;
				p2 *= norm.z;
				p3 *= norm.w;

				// Mix final noise value
				vec4 m = max(0.6 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0);
				m = m * m;
				return 42.0 * dot(m * m, vec4(dot(p0,x0), dot(p1,x1), dot(p2,x2), dot(p3,x3)));
			}

			// ── FBM: layered octaves for organic look ─────────────────────────────
			float fbm(vec3 p) {
				float value = 0.0;
				float amplitude = 0.5;
				float frequency = 1.0;
				// 4 octaves — balanced quality vs. cost
				for (int i = 0; i < 4; i++) {
					value += snoise(p * frequency) * amplitude;
					amplitude *= 0.5;
					frequency *= 2.0;
				}
				return value;
			}

			void main() {
				// Aspect-correct UVs centred at (0,0)
				vec2 aspect = vec2(uResolution.x / uResolution.y, 1.0);
				vec2 uv = (vUv - 0.5) * aspect;

				// Very slight mouse parallax — the noise field drifts toward cursor
				vec2 mouseOffset = (uMouse - 0.5) * 0.06;
				uv += mouseOffset;

				float t = uTime * 0.055;  // very slow evolution

				// ── Layer 1: large sweeping noise ──────────────────────────────────
				float n1 = fbm(vec3(uv * 0.9, t));

				// ── Layer 2: medium detail offset in time ──────────────────────────
				float n2 = fbm(vec3(uv * 1.8 + vec2(0.4, 0.7), t * 0.7 + 3.1));

				// Combine — normalise to [0, 1]
				float noise = (n1 * 0.65 + n2 * 0.35) * 0.5 + 0.5;

			// ── Base colour: near-black (matches --background #111111) ──────────
			// Site palette: dark void background
			vec3 bgColour  = vec3(0.067, 0.067, 0.067); // #111111
			vec3 bgStrong  = vec3(0.055, 0.055, 0.055); // #0e0e0e, slightly darker tone

			// ── Accent colour: amber/gold ──────────────────────────────────────
			// #D4A853 → appears only in the brightest noise peaks
			vec3 accentColour = vec3(0.831, 0.659, 0.325);

			// ── Highlight: subtle lighter traces — data flowing through darkness ─
			vec3 midColour = vec3(0.153, 0.153, 0.153); // #272727 — subtle noise highlight

			// Blend: base → highlight noise field at very low opacity
			float noiseBlend = noise * 0.18;  // max 18% deviation — very subtle
			vec3 colour = mix(bgColour, midColour, noiseBlend);

			// Amber accent only on the brightest peaks (top 15% of noise range)
			float accentMask = smoothstep(0.82, 0.97, noise);
			colour = mix(colour, accentColour, accentMask * 0.07); // max 7% amber glint

			// Vignette: deepen edges further into darkness for cinematic feel
			float dist = length((vUv - 0.5) * vec2(1.0, uResolution.y / uResolution.x));
			float vignette = 1.0 - smoothstep(0.30, 0.70, dist) * 0.35;
			colour *= vignette;

				gl_FragColor = vec4(colour, 1.0);
			}
		`;

		// ── Geometry & Material ───────────────────────────────────────────────────
		const geometry = new THREE.PlaneGeometry(2, 2);
		const uniforms = {
			uTime:       { value: 0.0 },
			uResolution: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) },
			uMouse:      { value: new THREE.Vector2(0.5, 0.5) },
		};

		const material = new THREE.ShaderMaterial({
			vertexShader,
			fragmentShader,
			uniforms,
		});

		const mesh = new THREE.Mesh(geometry, material);
		scene.add(mesh);

		// ── Resize ────────────────────────────────────────────────────────────────
		const onResize = () => {
			renderer.setSize(window.innerWidth, window.innerHeight, false);
			uniforms.uResolution.value.set(window.innerWidth, window.innerHeight);
		};

		onResize();

		const resizeObserver = new ResizeObserver(onResize);
		resizeObserver.observe(document.documentElement);
		cleanups.push(() => resizeObserver.disconnect());

		window.addEventListener("resize", onResize);
		cleanups.push(() => window.removeEventListener("resize", onResize));

		// ── Mouse tracking (throttled to avoid per-frame cost) ───────────────────
		let mouseX = 0.5;
		let mouseY = 0.5;
		let mouseDirty = false;

		const onMouseMove = (e: MouseEvent) => {
			mouseX = e.clientX / window.innerWidth;
			mouseY = 1.0 - e.clientY / window.innerHeight; // flip Y for GLSL
			mouseDirty = true;
		};

		if (!reduceMotion) {
			window.addEventListener("mousemove", onMouseMove, { passive: true });
			cleanups.push(() => window.removeEventListener("mousemove", onMouseMove));
		}

		// ── Animation loop ────────────────────────────────────────────────────────
		const clock = new THREE.Clock();
		let frameId = 0;
		// Smooth mouse interpolation target
		let smoothMouseX = 0.5;
		let smoothMouseY = 0.5;

		const renderFrame = () => {
			// Lazy mouse lerp — only update uniform when needed
			if (mouseDirty || Math.abs(smoothMouseX - mouseX) > 0.001 || Math.abs(smoothMouseY - mouseY) > 0.001) {
				smoothMouseX += (mouseX - smoothMouseX) * 0.04;
				smoothMouseY += (mouseY - smoothMouseY) * 0.04;
				uniforms.uMouse.value.set(smoothMouseX, smoothMouseY);
				mouseDirty = false;
			}

			uniforms.uTime.value = clock.getElapsedTime();
			renderer.render(scene, camera);

			frameId = window.requestAnimationFrame(renderFrame);
		};

		if (reduceMotion) {
			// Render one static frame and stop
			uniforms.uTime.value = 0;
			renderer.render(scene, camera);
		} else {
			renderFrame();
		}

		// ── Cleanup ───────────────────────────────────────────────────────────────
		const cleanup = () => {
			window.cancelAnimationFrame(frameId);
			cleanups.forEach((fn) => fn());
			geometry.dispose();
			material.dispose();
			renderer.dispose();
		};

		window.addEventListener("pagehide", cleanup, { once: true });
	}
</script>
