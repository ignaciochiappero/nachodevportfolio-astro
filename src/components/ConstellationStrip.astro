---
// ConstellationStrip.astro
// Particles.js-style effect — vanilla Canvas 2D, zero dependencies.
// White particles on dark/transparent background, connected by lines.
// Hover: repulse mode. Click: push (add particles).
---

<canvas
  class="constellation-strip"
  data-particles
  aria-hidden="true"
></canvas>

<style>
  .constellation-strip {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 220px;
    transform: translateY(-50%);
    z-index: 0;
    pointer-events: auto;
    display: block;
    background: transparent;
  }

  @media (prefers-reduced-motion: reduce) {
    .constellation-strip {
      display: none;
    }
  }
</style>

<script>
  // ── Guard: reduced motion ─────────────────────────────────────────────────
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    initParticles();
  }

  function initParticles() {
    const canvas = document.querySelector<HTMLCanvasElement>("[data-particles]");
    if (!canvas) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // ── Config ───────────────────────────────────────────────────────────────
    const isMobile = window.innerWidth < 768;
    const BASE_COUNT      = isMobile ? 50 : 80;
    const CONNECT_DIST    = 150;       // px — max line distance
    const REPULSE_DIST    = 150;       // px — mouse repulse radius
    const REPULSE_FORCE   = 80;        // how far particles get pushed (px)
    const BASE_SPEED      = 2;         // px/s base, scaled by 0.5-1.5×
    const AMBER_RATIO     = 0.04;      // ~4% amber particles

    // Dark-theme colours
    const DOT_COLOR_W     = "rgba(252,252,252,0.5)";
    const DOT_COLOR_A     = "rgba(212,168,83,0.4)";
    const LINE_COLOR_W_R  = 252; const LINE_COLOR_W_G = 252; const LINE_COLOR_W_B = 252;
    const LINE_BASE_A_W   = 0.08;      // white line base alpha
    const LINE_BASE_A_A   = 0.06;      // amber line base alpha

    // ── Canvas sizing ────────────────────────────────────────────────────────
    let W = 0;
    let H = 0;

    const resize = () => {
      const dpr = Math.min(window.devicePixelRatio, 2);
      const rect = canvas.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      canvas.width  = W * dpr;
      canvas.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    resize();

    // ── Particle type ────────────────────────────────────────────────────────
    type Particle = {
      x:     number;
      y:     number;
      vx:    number;
      vy:    number;
      r:     number;   // radius
      amber: boolean;
    };

    const particles: Particle[] = [];

    const createParticle = (x?: number, y?: number): Particle => {
      const angle = Math.random() * Math.PI * 2;
      const speed = BASE_SPEED * (0.5 + Math.random());
      return {
        x:     x ?? Math.random() * W,
        y:     y ?? Math.random() * H,
        vx:    Math.cos(angle) * speed,
        vy:    Math.sin(angle) * speed,
        r:     1 + Math.random() * 2,          // 1–3 px
        amber: Math.random() < AMBER_RATIO,
      };
    };

    // Spawn initial particles
    for (let i = 0; i < BASE_COUNT; i++) {
      particles.push(createParticle());
    }

    // ── Mouse state ──────────────────────────────────────────────────────────
    let mouseX = -9999;
    let mouseY = -9999;

    const onPointerMove = (e: PointerEvent) => {
      const rect = canvas.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    };

    const onPointerLeave = () => {
      mouseX = -9999;
      mouseY = -9999;
    };

    // Click → PUSH mode: add 4 particles at cursor position
    const onClick = (e: MouseEvent) => {
      const rect = canvas.getBoundingClientRect();
      const cx = e.clientX - rect.left;
      const cy = e.clientY - rect.top;
      for (let i = 0; i < 4; i++) {
        particles.push(createParticle(cx, cy));
      }
    };

    canvas.addEventListener("pointermove", onPointerMove, { passive: true });
    canvas.addEventListener("pointerleave", onPointerLeave, { passive: true });
    canvas.addEventListener("click", onClick);

    // ── ResizeObserver ───────────────────────────────────────────────────────
    const ro = new ResizeObserver(() => {
      resize();
    });
    ro.observe(canvas);

    // ── Animation loop ───────────────────────────────────────────────────────
    let frameId = 0;

    const animate = () => {
      frameId = requestAnimationFrame(animate);

      ctx.clearRect(0, 0, W, H);

      const len = particles.length;

      // ── Update positions ──────────────────────────────────────────────────
      for (let i = 0; i < len; i++) {
        const p = particles[i];

        // Repulse from cursor
        const dx = p.x - mouseX;
        const dy = p.y - mouseY;
        const d2 = dx * dx + dy * dy;

        if (d2 < REPULSE_DIST * REPULSE_DIST && d2 > 0.01) {
          const d   = Math.sqrt(d2);
          // Force: stronger when closer, zero at edge
          const f   = (1 - d / REPULSE_DIST) * (REPULSE_FORCE / d);
          p.vx += dx * f * 0.05;
          p.vy += dy * f * 0.05;

          // Clamp velocity so particles don't fly off too fast
          const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
          const maxSpeed = BASE_SPEED * 6;
          if (speed > maxSpeed) {
            p.vx = (p.vx / speed) * maxSpeed;
            p.vy = (p.vy / speed) * maxSpeed;
          }
        } else {
          // Gradually recover to natural speed (dampen excess)
          const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
          if (speed > BASE_SPEED * 1.5) {
            p.vx *= 0.98;
            p.vy *= 0.98;
          }
        }

        // Move
        p.x += p.vx;
        p.y += p.vy;

        // Wrap around edges (particles re-enter from opposite side)
        if (p.x < -p.r)  p.x = W + p.r;
        if (p.x > W + p.r) p.x = -p.r;
        if (p.y < -p.r)  p.y = H + p.r;
        if (p.y > H + p.r) p.y = -p.r;
      }

      // ── Draw lines ────────────────────────────────────────────────────────
      for (let i = 0; i < len; i++) {
        const pi = particles[i];
        for (let j = i + 1; j < len; j++) {
          const pj  = particles[j];
          const dx  = pi.x - pj.x;
          const dy  = pi.y - pj.y;
          const d2  = dx * dx + dy * dy;

          if (d2 > CONNECT_DIST * CONNECT_DIST) continue;

          const dist    = Math.sqrt(d2);
          const t       = 1 - dist / CONNECT_DIST;   // 1=close, 0=far
          const isAmber = pi.amber || pj.amber;
          const baseA   = isAmber ? LINE_BASE_A_A : LINE_BASE_A_W;
          const alpha   = baseA * t;

          if (isAmber) {
            ctx.strokeStyle = `rgba(212,168,83,${alpha.toFixed(3)})`;
          } else {
            ctx.strokeStyle = `rgba(${LINE_COLOR_W_R},${LINE_COLOR_W_G},${LINE_COLOR_W_B},${alpha.toFixed(3)})`;
          }

          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(pi.x, pi.y);
          ctx.lineTo(pj.x, pj.y);
          ctx.stroke();
        }
      }

      // ── Draw particles ────────────────────────────────────────────────────
      for (let i = 0; i < len; i++) {
        const p = particles[i];
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = p.amber ? DOT_COLOR_A : DOT_COLOR_W;
        ctx.fill();
      }
    };

    animate();

    // ── Cleanup ──────────────────────────────────────────────────────────────
    window.addEventListener("pagehide", () => {
      cancelAnimationFrame(frameId);
      canvas.removeEventListener("pointermove", onPointerMove);
      canvas.removeEventListener("pointerleave", onPointerLeave);
      canvas.removeEventListener("click", onClick);
      ro.disconnect();
    }, { once: true });
  }
</script>
