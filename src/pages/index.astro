---
import TechScene from "../components/TechScene.astro";
import ParticleLogo from "../components/ParticleLogo.astro";
import "../styles/global.css";
import {
	personalInfo,
	projects,
	socialNetworks,
	aboutText,
	statistics,
	careerTimeline,
} from "../data/portfolio-data";

// Sort: featured first, then by year descending
const sortedProjects = [...projects].sort((a, b) => {
	if (a.featured && !b.featured) return -1;
	if (!a.featured && b.featured) return 1;
	return b.year - a.year;
});

const projectCategoryLabels: Record<string, string> = {
	platform: "Platform",
	commerce: "E-Commerce",
	brand: "Brand / Portfolio",
	ai: "AI Application",
	vision: "Computer Vision",
};

// Social networks with proper display names for contact
const githubLink = socialNetworks.find((s) => s.name === "GitHub");
const linkedinLink = socialNetworks.find((s) => s.name === "LinkedIn");
const whatsappLink = socialNetworks.find((s) => s.name === "WhatsApp");
const youtubeLink = socialNetworks.find((s) => s.name === "YouTube");
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Nacho´s Dev Full Stack portfolio with a AI chat included"
		/>
		<title>Nacho Dev | Portfolio</title>
	</head>
	<body class="selection:bg-white/10 selection:text-white">
		<div class="site-shell">
			<TechScene />
			<div class="ambient-orb ambient-orb-left"></div>
			<div class="ambient-orb ambient-orb-right"></div>
			<div class="grid-surface"></div>

		<header class="pointer-events-none fixed inset-x-0 top-0 z-30">
				<div class="mx-auto flex max-w-400 items-center justify-between px-5 py-5 md:px-8 md:py-7">
					<a
						href="#top"
						class="pointer-events-auto inline-flex items-center gap-3 text-xs font-medium uppercase tracking-[0.35em] text-white/50 transition-opacity duration-200 hover:opacity-50"
					>
						<span class="inline-block h-2 w-2 rounded-full bg-white/80"></span>
						nachodev
					</a>
				</div>
			</header>

			<!-- ── PILL NAV ──────────────────────────────────────────────────── -->
			<nav class="pill-nav" id="pillNav" aria-label="Site navigation">
		<a href="#top" class="pill-nav__link pill-nav__link--active" data-section="top">Home</a>
		<a href="#works" class="pill-nav__link" data-section="works">Works</a>
		<a href="#about" class="pill-nav__link" data-section="about">About</a>
		<a href="#experience" class="pill-nav__link" data-section="experience">Experience</a>
		<a href="#contact" class="pill-nav__link" data-section="contact">Contact</a>
			</nav>


			<div class="section-label right-5 hidden md:block">Scroll to explore</div>

			<main id="top" class="relative z-10">
			<!-- ── HERO ──────────────────────────────────────────────────────── -->
			<section class="hero-section mx-auto flex min-h-dvh max-w-400 items-end px-5 pb-12 pt-28 md:px-8 md:pb-16 md:pt-36">
				<ParticleLogo />
				<div class="hero-content grid w-full gap-14 lg:grid-cols-[minmax(0,1.15fr)_minmax(280px,0.7fr)] lg:items-end lg:gap-10">
						<div class="max-w-5xl">

		

							<p class="mb-6 font-[GeistMono,monospace] text-[10px] uppercase tracking-[0.2em] text-white/40 md:mb-8">
								{personalInfo.name}  &mdash; {personalInfo.role}
							</p>

							<h1 class="max-w-[12ch] text-[clamp(3.6rem,10vw,8.75rem)] font-light uppercase leading-[0.88] tracking-[-0.03em] text-white">
								{personalInfo.tagline}
							</h1>

							<p class="mt-5 font-[GeistMono,monospace] text-[10px] uppercase tracking-[0.2em] text-white/40">
								 {personalInfo.location}
							</p>

							<div class="mt-10 flex flex-col gap-4 sm:flex-row md:mt-12">
								<a class="button-rect" href="#works">
									<span>Ver proyectos</span>
								</a>
								<a class="button-text" href="#contact">Hablemos</a>
							</div>

						</div>
					</div>
				</section>

			<!-- ── WORKS ─────────────────────────────────────────────────────── -->
			<section id="works" class="mx-auto max-w-400 px-5 py-14 md:px-8 md:py-20">
				<div class="mb-10 flex flex-col gap-5 border-t border-white/10 pt-6 md:mb-14 md:flex-row md:items-end md:justify-between">
					<div>
						<p class="font-[GeistMono,monospace] text-[10px] uppercase tracking-[0.2em] text-white/40">Selected works</p>
						<h2 class="mt-3 max-w-[10ch] text-[clamp(2.8rem,6vw,5.5rem)] font-light uppercase leading-[0.9] tracking-[-0.03em] text-white">
Mi trabajo						</h2>
					</div>
					<p class="max-w-md text-sm leading-7 text-white/40 md:text-base normal-case tracking-normal">
						Proyectos reales — plataformas, e-commerce, herramientas de IA y experimentos de computer vision.
					</p>
				</div>

				<div class="section-cards">
					{sortedProjects.map((project) => (
						<div class="project-card">
							{project.featured && (
								<span class="project-card__featured">Featured</span>
							)}
							<span class="project-card__year">{project.year}</span>
							<div class="project-card__image-container">
								<img src={project.image} alt={project.title} loading="lazy" decoding="async" />
								<div class="project-card__overlay">
									<div class="project-card__info">
										<h5 class="project-card__title">{project.title}</h5>
										<small class="project-card__category">
											<span class="project-card__category-dot" aria-hidden="true"></span>
											{projectCategoryLabels[project.category] ?? project.category}
										</small>
									</div>
								<a
									href={project.urlDemo || project.urlGithub || '#'}
									class="project-card__link"
									target="_blank"
									rel="noopener noreferrer"
								>
									<span class="project-card__link-text">View Project</span>
									<svg width="16" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
										<path d="M12 2C17.52 2 22 6.48 22 12C22 17.52 17.52 22 12 22C6.48 22 2 17.52 2 12C2 6.48 6.48 2 12 2ZM12 11H8V13H12V16L16 12L12 8V11Z"></path>
									</svg>
								</a>
								</div>
							</div>
						</div>
					))}
				</div>
			</section>

				<!-- ── ABOUT ─────────────────────────────────────────────────────── -->
				<section id="about" class="mx-auto max-w-400 px-5 py-14 md:px-8 md:py-20">
					<div class="border-t border-white/10 pt-6">
						<p class="section-tag">About</p>
						<h2 class="mt-3 max-w-[12ch] text-[clamp(2.6rem,5vw,4.5rem)] font-light uppercase leading-[0.92] tracking-[-0.03em] text-white">
							{personalInfo.name}
						</h2>

						<div class="about-content mt-10 grid gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(280px,0.9fr)] lg:gap-16">
							<div class="about-text space-y-5">
								{aboutText.map((paragraph) => (
									<p class="text-sm leading-7 text-white/40 md:text-base md:leading-8 normal-case tracking-normal">
										{paragraph}
									</p>
								))}
							</div>

							<div class="about-stats grid grid-cols-2 gap-x-8 gap-y-8 sm:grid-cols-4 lg:grid-cols-2">
								{statistics.map((stat) => (
									<div class="stat-item">
										<p class="stat-value">
											{stat.value}{stat.suffix ?? ""}
										</p>
										<p class="stat-label">{stat.label}</p>
									</div>
								))}
							</div>
						</div>
					</div>
				</section>

			<!-- ── EXPERIENCE ─────────────────────────────────────────────────── -->
				<section id="experience" class="mx-auto max-w-400 px-5 py-14 md:px-8 md:py-20">
					<div class="border-t border-white/10 pt-6">
						<p class="section-tag">Experience</p>
						<h2 class="mt-3 max-w-[10ch] text-[clamp(2.6rem,5vw,4.5rem)] font-light uppercase leading-[0.92] tracking-[-0.03em] text-white">
							Career
						</h2>

						<div class="timeline mt-10">
							{careerTimeline.map((entry) => (
								<div class="timeline-item">
									<p class="timeline-item__period">{entry.period}</p>
									<h3 class="timeline-item__title">{entry.title}</h3>
									<p class="timeline-item__role">{entry.role}</p>
									<p class="timeline-item__desc">{entry.description}</p>
								</div>
							))}
						</div>
					</div>
				</section>

				<!-- ── CONTACT ───────────────────────────────────────────────────── -->
				<footer id="contact" class="mx-auto max-w-400 px-5 pb-10 pt-14 md:px-8 md:pb-14 md:pt-20">
					<div class="grid gap-8 border-t border-white/10 pt-6 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-end">
						<div>
							<p class="font-[GeistMono,monospace] text-[10px] uppercase tracking-[0.2em] text-white/40">Contact</p>
							<h2 class="mt-3 max-w-[11ch] text-[clamp(2.4rem,5vw,4.5rem)] font-light uppercase leading-[0.92] tracking-[-0.03em] text-white">
								Let the next project be equally precise.
							</h2>
						</div>

						<div class="space-y-3 font-[GeistMono,monospace] text-sm uppercase tracking-[0.24em] text-white/40">
							<a
								class="block transition-opacity duration-200 hover:opacity-50"
								href={`mailto:${personalInfo.email}`}
							>
								{personalInfo.email}
							</a>

							{whatsappLink && (
								<a
									class="block transition-opacity duration-200 hover:opacity-50"
									href={whatsappLink.url}
									target="_blank"
									rel="noreferrer noopener"
								>
									WhatsApp
								</a>
							)}

							{githubLink && (
								<a
									class="block transition-opacity duration-200 hover:opacity-50"
									href={githubLink.url}
									target="_blank"
									rel="noreferrer noopener"
								>
									GitHub
								</a>
							)}

							{linkedinLink && (
								<a
									class="block transition-opacity duration-200 hover:opacity-50"
									href={linkedinLink.url}
									target="_blank"
									rel="noreferrer noopener"
								>
									LinkedIn
								</a>
							)}

							{youtubeLink && (
								<a
									class="block transition-opacity duration-200 hover:opacity-50"
									href={youtubeLink.url}
									target="_blank"
									rel="noreferrer noopener"
								>
									YouTube
								</a>
							)}
						</div>
					</div>
				</footer>
			</main>
		</div>
	</body>
</html>

<style>
  /* ── Hero section — positioning context for the constellation strip ─────── */

  .hero-section {
    position: relative;
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  /* ── Pill Navigation ─────────────────────────────────────────────────────── */

  .pill-nav {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 0;
    width: fit-content;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    background: rgba(17, 17, 17, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(252, 252, 252, 0.10);
    /* Mobile: allow horizontal scroll */
    max-width: calc(100vw - 2rem);
    overflow-x: auto;
    overflow-y: hidden;
    white-space: nowrap;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .pill-nav::-webkit-scrollbar {
    display: none;
  }

  .pill-nav__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.6rem;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(136, 136, 136, 1); /* --muted equivalent */
    text-decoration: none;
    transition: color 200ms ease;
    flex-shrink: 0;
  }

  .pill-nav__link:hover {
    color: #fcfcfc;
  }

  .pill-nav__link--active {
    color: #fcfcfc;
  }

  /* Active dot indicator */
  .pill-nav__link--active::before {
    content: "";
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 9999px;
    background: #D4A853;
    flex-shrink: 0;
    vertical-align: middle;
    margin-bottom: 1px;
  }

  /* Separator dots between links */
  .pill-nav__link + .pill-nav__link {
    margin-left: 0.25rem;
  }

  .pill-nav__link + .pill-nav__link::after {
    /* no separator — gap is enough */
  }

  /* On large screens, give a bit more gap */
  @media (min-width: 640px) {
    .pill-nav__link {
      padding: 0.3rem 0.75rem;
    }
  }
</style>

<script>
  // ── Project Cards — Scroll Reveal via IntersectionObserver ──────────────
  (function () {
    if (typeof IntersectionObserver === "undefined") {
      // Fallback: show all cards immediately
      document.querySelectorAll<HTMLElement>(".project-card").forEach((card) => {
        card.classList.add("is-visible");
      });
      return;
    }

    const cards = document.querySelectorAll<HTMLElement>(".project-card");
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
    );

    for (const card of cards) {
      observer.observe(card);
    }
  })();

  // ── Pill Nav — Active Section Tracking via IntersectionObserver ───────────
  (function () {
    const nav = document.getElementById("pillNav");
    if (!nav) return;

    const links = nav.querySelectorAll<HTMLAnchorElement>(".pill-nav__link[data-section]");
    if (!links.length) return;

    const sectionIds = Array.from(links).map((link) => link.dataset.section).filter(Boolean) as string[];

    // Map section id → nav link element
    const linkMap = new Map<string, HTMLAnchorElement>();
    for (const link of links) {
      const section = link.dataset.section;
      if (section) linkMap.set(section, link);
    }

    const setActive = (id: string) => {
      for (const link of links) {
        const isActive = link.dataset.section === id;
        link.classList.toggle("pill-nav__link--active", isActive);
      }
    };

    if (typeof IntersectionObserver === "undefined") {
      return;
    }

    // Track the most "visible" section
    const visibilityMap = new Map<string, number>();

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          visibilityMap.set(entry.target.id, entry.intersectionRatio);
        }

        // Find the section with highest intersection ratio
        let topId = "";
        let topRatio = -1;
        for (const [id, ratio] of visibilityMap) {
          if (ratio > topRatio) {
            topRatio = ratio;
            topId = id;
          }
        }

        if (topId) {
          // "top" section → "Home" link
          setActive(topId === "top" ? "top" : topId);
        }
      },
      { threshold: [0, 0.1, 0.25, 0.5, 0.75, 1.0], rootMargin: "-10% 0px -10% 0px" }
    );

    // Observe all relevant sections
    for (const id of sectionIds) {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    }
  })();
</script>
